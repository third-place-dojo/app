---
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Third Place Dojo - Coudersport, PA</title>
<meta name="description" content="A martial arts and community space in Coudersport, PA. Home of Kokoro-Jitsu." />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;1,9..144,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: #F5EFE6;
    color: #1E2A38;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(20,29,39,0.25);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }
  /* crop to the right half (badge) of the combined PNG */
  .nav-logo-crop {
    height: 48px;
    width: 48px;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
  }
  .nav-logo-img {
    height: 48px;
    width: auto;
    /* shift left to show only the right (badge) half */
    position: absolute;
    right: 0;
    mix-blend-mode: screen;
    filter: brightness(1.3);
  }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-size: 0.85rem; font-weight: 400; letter-spacing: 0.08em;
    text-transform: uppercase; color: #F0F4F8; text-decoration: none;
    opacity: 0.6; transition: opacity 0.2s, color 0.2s;
  }
  .nav-links a:hover { opacity: 1; color: #C94FAE; }
  .nav-cta {
    background: #C94FAE; color: #ffffff !important;
    opacity: 1 !important; padding: 0.5rem 1.25rem; border-radius: 2rem;
    font-weight: 500; transition: background 0.2s !important;
  }
  .nav-cta:hover { background: #a83d90 !important; }
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px; z-index: 101;
  }
  .hamburger span {
    display: block; width: 24px; height: 2px;
    background: #F0F4F8; border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .mobile-menu {
    display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(14,22,32,0.97); z-index: 99;
    flex-direction: column; align-items: center; justify-content: center; gap: 2rem;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700;
    color: #F0F4F8; text-decoration: none; transition: color 0.2s;
  }
  .mobile-menu a:hover { color: #C94FAE; }
  .mobile-menu .mobile-cta {
    background: #C94FAE; color: white; padding: 0.875rem 2.5rem;
    border-radius: 3rem; font-family: 'DM Sans', sans-serif;
    font-size: 1rem; font-weight: 500;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    background: #C94FAE; color: white; padding: 0.875rem 2rem;
    border-radius: 3rem; text-decoration: none; font-size: 0.9rem; font-weight: 500;
    letter-spacing: 0.04em; display: inline-block;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(201,79,174,0.35);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,79,174,0.5); }
  .btn-teal {
    background: #1D9E75; color: white; padding: 0.875rem 2rem;
    border-radius: 3rem; text-decoration: none; font-size: 0.9rem; font-weight: 500;
    letter-spacing: 0.04em; display: inline-block;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(29,158,117,0.3);
  }
  .btn-teal:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(29,158,117,0.4); }
  .btn-ghost {
    background: transparent; color: #1E2A38; padding: 0.875rem 2rem;
    border-radius: 3rem; border: 1.5px solid rgba(30,42,56,0.25);
    text-decoration: none; font-size: 0.9rem; font-weight: 400;
    letter-spacing: 0.04em; display: inline-block;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: #1D9E75; color: #1D9E75; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh; position: relative; overflow: hidden;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 6rem 2rem 4rem;
  }
  .slideshow { position: absolute; inset: 0; z-index: 0; }
  .slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center; background-repeat: no-repeat;
    opacity: 0; transition: opacity 1.5s ease-in-out;
    transform: scale(1.04);
    animation: kenBurns 8s ease-in-out infinite alternate;
  }
  .slide.active { opacity: 1; }
  .slideshow-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(14,22,32,0.72) 0%,
      rgba(14,22,32,0.55) 50%,
      rgba(14,22,32,0.80) 100%
    );
  }
  .hero-coming-soon {
    position: relative; z-index: 2;
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(201,79,174,0.15); border: 1px solid rgba(201,79,174,0.35);
    color: #C94FAE; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 2rem;
    margin-bottom: 1.5rem;
    opacity: 0; animation: fadeUp 0.7s ease forwards 0.2s;
  }
  .coming-dot {
    width: 6px; height: 6px; background: #C94FAE; border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  /* hero logo lockup */
  .hero-logo-lockup {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center;
    opacity: 0; animation: fadeUp 0.8s ease forwards 0.35s;
  }
  /* crop to the left half (full lockup) of the combined PNG */
  .hero-logo-crop {
    width: clamp(220px, 32vw, 400px);
    overflow: hidden;
    position: relative;
  }
  .hero-logo-img {
    height: clamp(200px, 30vw, 360px);
    width: auto;
    /* show only left half — shift right half out of view */
    max-width: none;
    mix-blend-mode: screen;
    filter: brightness(1.3) drop-shadow(0 4px 32px rgba(0,0,0,0.4));
  }

  .hero-tagline {
    position: relative; z-index: 2; margin-top: 1.75rem;
    font-family: 'Playfair Display', serif; font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    color: rgba(240,244,248,0.9); line-height: 1.4;
    opacity: 0; animation: fadeUp 0.8s ease forwards 0.5s;
  }
  .hero-tagline em { font-style: italic; color: #C94FAE; }
  .hero-sub {
    position: relative; z-index: 2; margin-top: 1rem;
    font-family: 'Fraunces', serif; font-size: 1rem;
    color: rgba(240,244,248,0.55); line-height: 1.7; max-width: 44ch;
    opacity: 0; animation: fadeUp 0.8s ease forwards 0.65s;
  }
  .hero-actions {
    position: relative; z-index: 2;
    display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
    margin-top: 2.25rem;
    opacity: 0; animation: fadeUp 0.8s ease forwards 0.8s;
  }
  .hero-scroll-hint {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(240,244,248,0.3);
    opacity: 0; animation: fadeIn 1s ease forwards 1.4s;
  }
  .scroll-line {
    width: 1px; height: 36px;
    background: linear-gradient(180deg, rgba(240,244,248,0.4), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  /* ── ABOUT ── */
  .about-strip {
    background: #F0F4F8; padding: 5rem; position: relative; overflow: hidden;
  }
  .about-strip::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, #C94FAE, #1D9E75);
  }
  .about-inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
  }
  .about-heading {
    font-family: 'Playfair Display', serif; font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1.2; color: #1E2A38;
  }
  .about-heading em { font-style: italic; color: #C94FAE; }
  .about-body {
    font-family: 'Fraunces', serif; font-size: 1.05rem; line-height: 1.85;
    color: #1E2A38; opacity: 0.8; margin-bottom: 1.75rem;
  }
  .about-body p + p { margin-top: 1rem; }
  .about-body strong { font-weight: 600; color: #1E2A38; }

  /* ── PILLARS ── */
  .pillars-section { display: grid; grid-template-columns: repeat(3, 1fr); }
  .pillar { padding: 4rem 2.5rem; }
  .pillar-train { background: #141d27; }
  .pillar-gather { background: #1E2A38; }
  .pillar-belong { background: #1D9E75; }
  .pillar-label {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; margin-bottom: 1rem; display: block;
  }
  .pillar-train .pillar-label,
  .pillar-gather .pillar-label { color: #C94FAE; }
  .pillar-belong .pillar-label { color: rgba(4,52,44,0.7); }
  .pillar-heading {
    font-family: 'Playfair Display', serif; font-size: 2rem;
    font-weight: 700; margin-bottom: 1rem; line-height: 1.1;
  }
  .pillar-train .pillar-heading,
  .pillar-gather .pillar-heading { color: #F0F4F8; }
  .pillar-belong .pillar-heading { color: #04342C; }
  .pillar-body { font-size: 0.95rem; line-height: 1.75; margin-bottom: 2rem; }
  .pillar-train .pillar-body,
  .pillar-gather .pillar-body { color: rgba(240,244,248,0.65); }
  .pillar-belong .pillar-body { color: #085041; }
  .pillar-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.85rem; font-weight: 500; text-decoration: none; transition: gap 0.2s;
  }
  .pillar-train .pillar-link,
  .pillar-gather .pillar-link { color: #C94FAE; }
  .pillar-belong .pillar-link { color: #04342C; }
  .pillar-link:hover { gap: 0.8rem; }

  /* ── FUNDRAISING ── */
  .fundraise-section {
    background: #1E2A38; padding: 6rem 5rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;
    position: relative; overflow: hidden;
  }
  .fundraise-section::before {
    content: '場'; position: absolute; right: 2rem; bottom: -2rem;
    font-size: 18rem; font-family: serif; color: rgba(255,255,255,0.03);
    line-height: 1; user-select: none;
  }
  .fundraise-left { position: relative; z-index: 1; }
  .fundraise-label {
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.2em;
    text-transform: uppercase; color: #C94FAE; margin-bottom: 1rem; display: block;
  }
  .fundraise-heading {
    font-family: 'Playfair Display', serif; font-size: clamp(2rem, 3.5vw, 3rem);
    color: #ffffff; line-height: 1.2; margin-bottom: 1.5rem;
  }
  .fundraise-heading em { font-style: italic; color: #C94FAE; }
  .fundraise-body {
    font-family: 'Fraunces', serif; font-size: 1.05rem; line-height: 1.9;
    color: rgba(240,244,248,0.65); margin-bottom: 2rem;
  }
  .fundraise-body strong { color: #ffffff; font-weight: 600; }
  .fundraise-buttons { display: flex; gap: 1rem; flex-wrap: wrap; }
  .fundraise-right { position: relative; z-index: 1; }
  .fundraise-cards { display: flex; flex-direction: column; gap: 1rem; }
  .fundraise-card {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem; padding: 1.75rem;
    display: flex; align-items: flex-start; gap: 1.25rem;
  }
  .fundraise-card-icon { font-size: 1.75rem; flex-shrink: 0; line-height: 1; margin-top: 0.1rem; }
  .fundraise-card-text { flex: 1; }
  .fundraise-card-title {
    font-family: 'Playfair Display', serif; font-size: 1.05rem;
    color: #ffffff; margin-bottom: 0.3rem;
  }
  .fundraise-card-desc { font-size: 0.88rem; line-height: 1.6; color: rgba(240,244,248,0.55); }

  /* ── TEASERS ── */
  .teasers-section { padding: 7rem 5rem; background: #F5EFE6; }
  .teasers-label {
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.2em;
    text-transform: uppercase; color: #1D9E75; margin-bottom: 1rem;
  }
  .teasers-title {
    font-family: 'Playfair Display', serif; font-size: clamp(2rem, 3vw, 2.5rem);
    color: #1E2A38; margin-bottom: 3rem;
  }
  .teasers-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;
  }
  .teaser-card {
    background: #F0F4F8; border-radius: 1.25rem; padding: 2rem 1.75rem;
    border: 1px solid rgba(30,42,56,0.07); transition: transform 0.25s, box-shadow 0.25s;
    display: flex; flex-direction: column; text-decoration: none; color: inherit;
    position: relative; overflow: hidden;
  }
  .teaser-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(30,42,56,0.09); }
  .teaser-kanji {
    position: absolute; right: -0.75rem; bottom: -1.5rem;
    font-family: serif; font-size: 9rem; line-height: 1;
    color: #1E2A38; opacity: 0.05; user-select: none; pointer-events: none;
  }
  .teaser-kanji.magenta { color: #C94FAE; opacity: 0.07; }
  .teaser-kanji.teal { color: #1D9E75; opacity: 0.1; }
  .teaser-content { position: relative; z-index: 1; display: flex; flex-direction: column; flex-grow: 1; }
  .teaser-tag {
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; padding: 0.25rem 0.75rem; border-radius: 2rem;
    margin-bottom: 1rem; display: inline-block; align-self: flex-start;
  }
  .teaser-tag.magenta { background: rgba(201,79,174,0.1); color: #C94FAE; }
  .teaser-tag.teal { background: rgba(29,158,117,0.1); color: #1D9E75; }
  .teaser-tag.slate { background: rgba(30,42,56,0.08); color: #1E2A38; }
  .teaser-name {
    font-family: 'Playfair Display', serif; font-size: 1.35rem;
    color: #1E2A38; margin-bottom: 0.6rem;
  }
  .teaser-desc { font-size: 0.9rem; line-height: 1.7; color: #1E2A38; opacity: 0.65; flex-grow: 1; }
  .teaser-arrow {
    margin-top: 1.5rem; font-size: 0.85rem; font-weight: 500;
    color: #C94FAE; display: flex; align-items: center; gap: 0.4rem; transition: gap 0.2s;
  }
  .teaser-card:hover .teaser-arrow { gap: 0.7rem; }

  /* ── FOOTER ── */
  footer {
    background: #141d27; padding: 3rem 5rem;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1.5rem;
  }
  .footer-brand-lockup {
    display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem;
  }
  .footer-logo-img {
    height: 52px; width: auto;
    mix-blend-mode: screen;
    filter: brightness(1.1);
    opacity: 0.85;
  }
  .footer-sub { font-size: 0.78rem; color: rgba(240,244,248,0.4); margin-top: 0.25rem; }
  .footer-directions { font-size: 0.78rem; margin-top: 0.35rem; }
  .footer-directions a { color: #1D9E75; text-decoration: none; }
  .footer-directions a:hover { text-decoration: underline; }
  .footer-copy { font-size: 0.72rem; color: rgba(240,244,248,0.2); margin-top: 0.35rem; }
  .footer-links { display: flex; gap: 1.5rem; list-style: none; flex-wrap: wrap; }
  .footer-links a {
    font-size: 0.8rem; color: rgba(240,244,248,0.5); text-decoration: none;
    letter-spacing: 0.06em; transition: color 0.2s;
  }
  .footer-links a:hover { color: #1D9E75; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.9; }
  }
  @keyframes kenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.06); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .hero { padding: 5rem 1.75rem 4rem; }
    .about-strip { padding: 4rem 1.75rem; }
    .about-inner { grid-template-columns: 1fr; gap: 2rem; }
    .pillars-section { grid-template-columns: 1fr; }
    .fundraise-section { grid-template-columns: 1fr; gap: 3rem; padding: 4rem 1.75rem; }
    .teasers-section { padding: 4rem 1.75rem; }
    footer { padding: 2rem; flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<!-- ── NAV ── -->
<nav>
  <a href="/" class="nav-logo">
    <div class="nav-logo-crop">
      <img src="/logo-full.png" alt="Third Place Dojo" class="nav-logo-img">
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="/train">Train</a></li>
    <li><a href="/events">Events</a></li>
    <li><a href="/pricing">Pricing</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="https://ko-fi.com/kokorojitsu" class="nav-cta">Support Us</a></li>
  </ul>
  <button class="hamburger" id="hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- ── MOBILE MENU ── -->
<div class="mobile-menu" id="mobile-menu">
  <a href="/train">Train</a>
  <a href="/events">Events</a>
  <a href="/pricing">Pricing</a>
  <a href="/about">About</a>
  <a href="https://ko-fi.com/kokorojitsu" target="_blank" class="mobile-cta">Support Us</a>
</div>

<!-- ── HERO ── -->
<section class="hero">
  <div class="slideshow">
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
  </div>
  <div class="slideshow-overlay"></div>

  <div class="hero-coming-soon">
    <div class="coming-dot"></div>
    Coming Soon — Opening Monday, May 4th
  </div>

  <div class="hero-logo-lockup">
    <div class="hero-logo-crop">
      <img src="/logo-full.png" alt="Third Place Dojo" class="hero-logo-img">
    </div>
  </div>

  <p class="hero-tagline">Train. Gather. <em>Belong.</em></p>
  <p class="hero-sub">Home is the first place. Work and school are the second. Third Place Dojo is everything in between.</p>
  <div class="hero-actions">
    <a href="/train" class="btn-primary">Train with us</a>
    <a href="/events" class="btn-teal">See events</a>
  </div>
  <div class="hero-scroll-hint">
    <div class="scroll-line"></div>
    Scroll
  </div>
</section>

<!-- ── ABOUT ── -->
<section class="about-strip">
  <div class="about-inner">
    <h2 class="about-heading">Not a gym.<br>Not a club.<br><em>A third place.</em></h2>
    <div class="about-right">
      <div class="about-body">
        <p>Ray Oldenburg coined the third place as the social spaces between home and work where real community happens. Barbershops, coffee shops, parks. We believe a <strong>dojo can be that</strong> for Coudersport.</p>
        <p>People showing up, moving their bodies, and getting a little better at life together.</p>
      </div>
      <a href="/about" class="btn-ghost">Our story</a>
    </div>
  </div>
</section>

<!-- ── PILLARS ── -->
